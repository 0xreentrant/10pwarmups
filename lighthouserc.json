{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "settings": {
        "onlyCategories": ["pwa"]
      }
    },
    "assert": {
      "assertions": {
        "installable-manifest": "error",
        "splash-screen": "error",
        "themed-omnibox": "error",
        "content-width": "error",
        "viewport": "error"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
