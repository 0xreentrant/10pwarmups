digraph DeckRenderingSystem {
  bgcolor = "#0f0f0f";
  node [fillcolor="#1a1a1a", fontcolor="#e8e8e8", color="#2e2e2e", style=filled, fontname="monospace"];
  edge [color="#666", fontname="monospace", fontsize=9];
  
  rankdir = TB;
  
  // Data Layer
  subgraph cluster_data {
    label = "Data Layer";
    color = "#2e2e2e";
    style = filled;
    fillcolor = "#0f0f0f";
    
    DECKS [label="DECKS\n(32 Deck Objects)", shape=box];
    SERIES [label="SERIES\n(8 Series Groups)", shape=box];
    PROGRESS [label="Progress State\n(currentStreak, bestStreak,\nattempts[])", shape=box];
    SESSION [label="Session State\n(moveSequence, options,\nlocked, finalAttempt)", shape=box];
  }
  
  // App State
  subgraph cluster_app {
    label = "App State Management";
    color = "#2e2e2e";
    style = filled;
    fillcolor = "#0f0f0f";
    
    APP [label="App Component\n(Main Router)", shape=ellipse];
    VIEW [label="view State\n(home|training|\ncompletion|progress)", shape=box];
    CURRENT_DECK [label="currentDeckId State", shape=box];
  }
  
  // Rendering Layer
  subgraph cluster_screens {
    label = "Screen Components";
    color = "#2e2e2e";
    style = filled;
    fillcolor = "#0f0f0f";
    
    HOME [label="HomeScreen\n→ SeriesGroups\n→ DeckRows", shape=component, color="#c0392b"];
    TRAINING [label="TrainingScreen\n→ MoveSequence\n→ Options", shape=component, color="#c0392b"];
    COMPLETION [label="CompletionScreen\n→ Results\n→ NextDeck", shape=component, color="#c0392b"];
    PROGRESS_SCREEN [label="ProgressScreen\n→ AllDecksOverview\n→ DeckProgress", shape=component, color="#c0392b"];
  }
  
  // Sub-components
  subgraph cluster_subcomp {
    label = "Sub-Components";
    color = "#2e2e2e";
    style = filled;
    fillcolor = "#0f0f0f";
    
    MOVE_LABEL [label="MoveLabel\n(Render Move Text)", shape=box];
    SERIES_GROUP [label="SeriesGroup\n(Table Rows)", shape=box];
    DECK_ROW [label="DeckRow\n(ID, Name, Progress\nBar, Train Button)", shape=box];
    ATTEMPT_HISTORY [label="AttempptHistory\n(Table of Attempts)", shape=box];
  }
  
  // Data Flow Connections
  DECKS -> SERIES [label="grouped by\nseries.id"];
  DECKS -> SESSION [label="move data"];
  PROGRESS -> SESSION [label="streak tracking"];
  DECKS -> PROGRESS [label="deck metrics"];
  
  // App Routing
  APP -> VIEW [label="controls view"];
  APP -> CURRENT_DECK [label="tracks selection"];
  
  // View to Screen Mapping
  VIEW -> HOME [label="view === 'home'"];
  VIEW -> TRAINING [label="view === 'training'"];
  VIEW -> COMPLETION [label="view === 'completion'"];
  VIEW -> PROGRESS_SCREEN [label="view === 'progress'"];
  
  // Screen Dependencies
  HOME -> DECKS [label="reads"];
  HOME -> SERIES [label="reads"];
  HOME -> PROGRESS [label="reads"];
  HOME -> SERIES_GROUP [label="renders"];
  HOME -> DECK_ROW [label="renders"];
  
  TRAINING -> DECKS [label="reads"];
  TRAINING -> SESSION [label="reads"];
  TRAINING -> MOVE_LABEL [label="renders"];
  
  COMPLETION -> DECKS [label="reads"];
  COMPLETION -> PROGRESS [label="reads"];
  COMPLETION -> SESSION [label="reads"];
  COMPLETION -> MOVE_LABEL [label="renders"];
  
  PROGRESS_SCREEN -> DECKS [label="reads"];
  PROGRESS_SCREEN -> PROGRESS [label="reads"];
  PROGRESS_SCREEN -> ATTEMPT_HISTORY [label="renders"];
  
  // Training Flow (example sequence)
  subgraph cluster_flow {
    label = "Training Flow Example";
    color = "#2e2e2e";
    style = filled;
    fillcolor = "#0f0f0f";
    
    START [label="1. startDeck(deckId)", shape=box, color="#27ae60"];
    SELECT_MOVE [label="2. handleOptionClick()", shape=box, color="#27ae60"];
    UPDATE_SESSION [label="3. Update Session\n(moveSequence,\ncurrentStreak)", shape=box, color="#27ae60"];
    NEXT_MOVE [label="4. Generate Next\nOptions", shape=box, color="#27ae60"];
    COMPLETE [label="5. Final Move?\nSave Attempt", shape=box, color="#27ae60"];
  }
  
  START -> SELECT_MOVE [label="generates options"];
  SELECT_MOVE -> UPDATE_SESSION;
  UPDATE_SESSION -> NEXT_MOVE;
  NEXT_MOVE -> SELECT_MOVE [label="loop"];
  SELECT_MOVE -> COMPLETE [label="last move"];
  COMPLETE -> COMPLETION [label="render"];
}
