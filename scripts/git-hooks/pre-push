#!/bin/sh
# Bumps the release version when pushing main. A commit created here cannot
# join the in-flight push (git resolves SHAs before hooks run), so we commit
# the bump and abort with instructions to push again. The bump script is a
# no-op when HEAD is already the bump commit, so the retry passes straight through.

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    node scripts/bumpReleaseVersion.mjs

    if ! git diff --quiet -- src/data/whatsNew.ts package.json package-lock.json; then
      git commit -m "chore: bump release version" -- src/data/whatsNew.ts package.json package-lock.json
      echo ""
      echo "Release version bumped and committed."
      echo "Run 'git push' again to include the bump commit."
      exit 1
    fi
  fi
done

exit 0
