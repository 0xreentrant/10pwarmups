digraph {
  rankdir = TB;
  bgcolor = "#0f0f0f";
  node [shape=box, style="rounded,filled", fillcolor="#1a1a1a", fontcolor="#e8e8e8", color="#2e2e2e", fontname="monospace"];
  edge [color="#666"];

  // ─── DATA STRUCTURES ───
  SERIES [label="SERIES\n{id, name}", fillcolor="#2d3142"];
  DECKS [label="DECKS[]\n{id, series, name, moves[]}", fillcolor="#2d3142"];
  Move [label="Move\n{text, partner}", fillcolor="#1a2847"];
  
  Progress [label="Progress (State)\nDeckStats {}\n  currentStreak\n  bestStreak\n  lastAttemptDate\n  attempts[]", fillcolor="#2a3d1a"];
  
  Attempt [label="Attempt\n{date, finalStreak,\n wrongMoves[], duration}", fillcolor="#1a2847"];
  
  Session [label="Session (State)\n{moveSequence[],\n currentStreak,\n startTime,\n options[],\n locked}", fillcolor="#2a3d1a"];

  // ─── RENDERING SYSTEM ───
  App [label="App (Main)\nState Management", fillcolor="#3d1a1a"];
  
  GlobalStyles [label="GlobalStyles\nCSS Variables\nTheme", fillcolor="#1a1a1a"];
  
  ViewRouter [label="View Router\n'home' | 'training' |\n'completion' | 'progress'", fillcolor="#2d2d2d"];
  
  HomeView [label="HomeView\nDeck Selector"];
  TrainingView [label="TrainingView\nMove Quiz"];
  CompletionView [label="CompletionView\nResults"];
  ProgressView [label="ProgressView\nStats & History"];
  
  MoveLabel [label="MoveLabel\n(Sub-component)"];

  // ─── STORAGE ───
  LocalStorage [label="LocalStorage\ntp_progress", fillcolor="#1a3d2a", shape=cylinder];

  // ─── CONNECTIONS ───
  
  // Data structure relationships
  DECKS -> SERIES [label="references"];
  DECKS -> Move [label="contains"];
  Progress -> Attempt [label="contains"];
  Session -> Move [label="evaluates"];
  
  // App to state
  App -> Progress [label="manages"];
  App -> Session [label="manages"];
  App -> GlobalStyles;
  
  // App to routing
  App -> ViewRouter;
  ViewRouter -> HomeView;
  ViewRouter -> TrainingView;
  ViewRouter -> CompletionView;
  ViewRouter -> ProgressView;
  
  // Views to components
  TrainingView -> MoveLabel;
  CompletionView -> MoveLabel;
  ProgressView -> Progress;
  HomeView -> DECKS;
  
  // Persistence
  App -> LocalStorage [label="load/save"];
  Progress -> LocalStorage;
  
  // Constant data
  App -> DECKS [label="references"];
  App -> SERIES [label="references"];

  // Styling
  GlobalStyles -> HomeView;
  GlobalStyles -> TrainingView;
  GlobalStyles -> CompletionView;
  GlobalStyles -> ProgressView;
}
